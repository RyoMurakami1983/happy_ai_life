{
  "schemaVersion": 1,
  "purpose": "Draft source of truth for Copilot CLI guard policy. Promote to policy/guard-policy.json after review.",
  "responsePolicy": {
    "permissionRequest": {
      "deny": "return deny response with interrupt=true",
      "ask": "do not ask here; fall through to normal permission flow"
    },
    "preToolUse": {
      "deny": "return deny response",
      "ask": "return ask response for protected path changes"
    }
  },
  "protectedPaths": [
    ".github/hooks/**",
    ".githooks/**",
    ".github/workflows/**",
    ".github/copilot-instructions.md",
    ".github/instructions/**",
    ".github/skills/**",
    ".agents/skills/**",
    ".claude/skills/**",
    ".github/mcp.json",
    ".mcp.json",
    ".gitleaks.toml",
    "SECURITY.md",
    "docs/TRUST_BOUNDARY.md",
    "docs/HOOKS_GOVERNANCE.md",
    "docs/ENTERPRISE_SECURITY_REVIEW.md",
    "docs/ENTERPRISE_SECURITY.md",
    "docs/ISSUE_ROADMAP_ENTERPRISE_SECURITY.md",
    "docs/AI_REPRO_SECURITY_ROADMAP.md",
    "docs/COPILOT_CLI_HANDOFF_AI_REPRO_SECURITY.md",
    "scripts/sync-to-home.ps1",
    "scripts/sync-to-repo.ps1",
    "scripts/repo-secure-check.ps1",
    "home-template/.copilot/**",
    "$HOME/.copilot/**",
    "~/.copilot/**"
  ],
  "denyCommandPatterns": [
    { "id": "git-commit-no-verify", "pattern": "git commit --no-verify" },
    { "id": "git-commit-short-no-verify", "pattern": "git commit -n" },
    { "id": "git-push-no-verify", "pattern": "git push --no-verify" },
    { "id": "git-push-force", "pattern": "git push -f|git push --force|git push --force-with-lease" },
    { "id": "git-reset-hard", "pattern": "git reset --hard" },
    { "id": "git-hooks-path-change", "pattern": "git config core.hooksPath|git config --unset core.hooksPath|git -c core.hooksPath" },
    { "id": "git-update-index-bypass", "pattern": "git update-index --skip-worktree|git update-index --assume-unchanged" },
    { "id": "powershell-encoded-command", "pattern": "powershell -EncodedCommand|pwsh -EncodedCommand|powershell -enc|pwsh -enc" },
    { "id": "powershell-iex", "pattern": "Invoke-Expression|iex" },
    { "id": "remote-script-pipe", "pattern": "curl ... | sh|wget ... | sh" },
    { "id": "destructive-rm", "pattern": "rm -rf /|rm -rf ." },
    { "id": "destructive-system", "pattern": "mkfs|format|shutdown|reboot|poweroff|Stop-Computer|Restart-Computer" }
  ],
  "toolNames": {
    "shell": ["bash", "powershell"],
    "fileWrite": ["create", "edit"],
    "observe": ["view", "web_fetch"],
    "delegation": ["task"]
  },
  "pathPropertyNames": ["path", "filePath", "file_path", "targetPath", "target_path"],
  "requiredTools": [
    { "name": "git", "minimumVersion": null, "requiredWhen": "always" },
    { "name": "gitleaks", "minimumVersion": null, "requiredWhen": "secret scan enabled" },
    { "name": "pwsh or powershell", "minimumVersion": null, "requiredWhen": "PowerShell wrapper enabled" },
    { "name": "jq", "minimumVersion": null, "requiredWhen": "legacy Bash hook uses jq" },
    { "name": "node", "minimumVersion": null, "requiredWhen": "session-continuity hook enabled" },
    { "name": "gh", "minimumVersion": null, "requiredWhen": "session-start hook queries GitHub issues" }
  ]
}

{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": "bash .github/hooks/scripts/guard_pre_tool.sh",
        "powershell": "powershell -NoProfile -File .github/hooks/scripts/guard_pre_tool.ps1",
        "cwd": ".",
        "timeoutSec": 10,
        "env": {
          "COPILOT_HOOK_MODE": "guard"
        }
      }
    ]
  }
}

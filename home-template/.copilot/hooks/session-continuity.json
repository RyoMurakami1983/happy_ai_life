{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "node \"$HOME/.copilot/hooks/scripts/session-start.js\"",
        "powershell": "node \"$HOME/.copilot/hooks/scripts/session-start.js\"",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "node \"$HOME/.copilot/hooks/scripts/session-end.js\"",
        "powershell": "node \"$HOME/.copilot/hooks/scripts/session-end.js\"",
        "cwd": ".",
        "timeoutSec": 15
      }
    ]
  }
}

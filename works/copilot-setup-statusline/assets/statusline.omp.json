{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": false,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "git",
          "style": "plain",
          "foreground": "#14A5AE",
          "template": "{{ if .HEAD }}{{ .UpstreamIcon }}{{ .HEAD }}{{ if .Working.Changed }} +{{ .Working.String }}{{ end }} | {{ end }}",
          "properties": {
            "fetch_status": true,
            "fetch_upstream_icon": true
          }
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#45F1C2",
          "template": "{{ if .Env.COPILOT_STATUS_TOOLING }}{{ .Env.COPILOT_STATUS_TOOLING }} | {{ end }}"
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#0CA0D8",
          "template": "ctx {{ .Env.COPILOT_STATUS_CONTEXT }} | "
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#CD4277",
          "template": "{{ .Env.COPILOT_STATUS_GAUGE }} | "
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#45F1C2",
          "template": "{{ .Env.COPILOT_STATUS_DURATION }} "
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#cd5e42",
          "template": "{{ if .Env.COPILOT_STATUS_CHANGES }}| {{ .Env.COPILOT_STATUS_CHANGES }} {{ end }}"
        }
      ]
    }
  ]
}
